use std::collections::HashMap;
use crate::native_fun::{NativeFun, add_default_fn_natives};
use crate::value::Value;

pub struct NativeMap {
    map: HashMap<String, Value>,
}

impl NativeMap {
    pub fn new() -> Self {
        Self {
            map: HashMap::new(),
        }
    }

    pub(crate) fn get(&self, ns_name: &String, name: &String) -> Option<Value> {
        if let Some(value) = self.map.get(name) {
            Some(value.clone())
        } else {
            None
	}
    }

    pub fn set(&self, ns_name: &String, name: &String, val: &Value) {
        match *val {
            Value::NativeFun(f) /* |
            Value::NativeClass(c)*/ => {
                if let Some(value) = self.map.get(name) {
                    eprintln!("native object {} already exists", (*val).value_type());
                    return;
                }

                self.map.insert(name.to_string(), val.clone());
            },
            _ => {
                eprintln!("cannot add {}: invalid type", (*val).value_type());
            }
        }
    }
}

pub(crate) fn add_default_natives() -> NativeMap {
    let mut map: NativeMap = NativeMap::new();
    add_default_fn_natives(&mut map);

    map
}
